        "processing_run_id": "run_m1002_manual_mapping"
      },
      "document_id": "doc_m1002_case_a",
      "unit_type": "paragraph",
      "sequence_no": 3,
      "text": "管理层认为行业温和复苏、AI芯片需求强劲，同时成熟制程存在过剩风险，并预计2026年销售收入保持两位数增长。",
      "locator": {
        "paragraph_no": 3
      },
      "speaker": "中芯国际"
    },
