{
  "$defs": {
    "ParseStatus": {
      "enum": [
        "discovered",
        "queued",
        "collected",
        "parsed",
        "partially_parsed",
        "failed",
        "archived",
        "superseded"
      ],
      "title": "ParseStatus",
      "type": "string"
    },
    "ParserDescriptor": {
      "additionalProperties": false,
      "properties": {
        "name": {
          "title": "Name",
          "type": "string"
        },
        "version": {
          "title": "Version",
          "type": "string"
        }
      },
      "required": [
        "name",
        "version"
      ],
      "title": "ParserDescriptor",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "status": {
      "const": "success",
      "default": "success",
      "title": "Status",
      "type": "string"
    },
    "processing_run_id": {
      "title": "Processing Run Id",
      "type": "string"
    },
    "source_id": {
      "title": "Source Id",
      "type": "string"
    },
    "document_id": {
      "title": "Document Id",
      "type": "string"
    },
    "content_unit_ids": {
      "items": {
        "type": "string"
      },
      "title": "Content Unit Ids",
      "type": "array"
    },
    "content_unit_count": {
      "minimum": 0,
      "title": "Content Unit Count",
      "type": "integer"
    },
    "content_hash": {
      "title": "Content Hash",
      "type": "string"
    },
    "raw_content_hash": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Raw Content Hash"
    },
    "parser_config_hash": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Parser Config Hash"
    },
    "parse_status": {
      "$ref": "#/$defs/ParseStatus",
      "default": "parsed"
    },
    "idempotency_key": {
      "title": "Idempotency Key",
      "type": "string"
    },
    "reused": {
      "default": false,
      "title": "Reused",
      "type": "boolean"
    },
    "dry_run": {
      "default": false,
      "title": "Dry Run",
      "type": "boolean"
    },
    "parser": {
      "$ref": "#/$defs/ParserDescriptor"
    },
    "warnings": {
      "items": {
        "type": "string"
      },
      "title": "Warnings",
      "type": "array"
    },
    "metrics": {
      "additionalProperties": true,
      "title": "Metrics",
      "type": "object"
    }
  },
  "required": [
    "processing_run_id",
    "source_id",
    "document_id",
    "content_unit_count",
    "content_hash",
    "idempotency_key",
    "parser"
  ],
  "title": "IngestionResult",
  "type": "object",
  "$id": "https://aurora.local/schemas/ingestion/v1_1/ingestion_result.schema.json"
}
