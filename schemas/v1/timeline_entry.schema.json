{
  "$defs": {
    "HumanReview": {
      "additionalProperties": false,
      "properties": {
        "status": {
          "$ref": "#/$defs/HumanReviewStatus",
          "default": "not_reviewed"
        },
        "reviewed_by": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Reviewed By"
        },
        "reviewed_at": {
          "anyOf": [
            {
              "format": "date-time",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Reviewed At"
        },
        "note": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Note"
        }
      },
      "title": "HumanReview",
      "type": "object"
    },
    "HumanReviewStatus": {
      "enum": [
        "not_reviewed",
        "reviewed",
        "approved",
        "rejected",
        "needs_revision"
      ],
      "title": "HumanReviewStatus",
      "type": "string"
    },
    "LifecycleStatus": {
      "enum": [
        "active",
        "archived",
        "superseded",
        "deleted"
      ],
      "title": "LifecycleStatus",
      "type": "string"
    },
    "OriginType": {
      "enum": [
        "original",
        "imported",
        "derived",
        "user_created"
      ],
      "title": "OriginType",
      "type": "string"
    },
    "PrivacyLevel": {
      "enum": [
        "public",
        "internal",
        "private",
        "sensitive",
        "restricted"
      ],
      "title": "PrivacyLevel",
      "type": "string"
    },
    "Provenance": {
      "additionalProperties": false,
      "properties": {
        "origin_type": {
          "$ref": "#/$defs/OriginType",
          "default": "original"
        },
        "origin_object_ids": {
          "items": {
            "type": "string"
          },
          "title": "Origin Object Ids",
          "type": "array"
        },
        "processing_run_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Processing Run Id"
        },
        "human_review": {
          "$ref": "#/$defs/HumanReview"
        },
        "derivation_note": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Derivation Note"
        },
        "source_locator_required": {
          "default": false,
          "title": "Source Locator Required",
          "type": "boolean"
        }
      },
      "title": "Provenance",
      "type": "object"
    },
    "TimePrecision": {
      "enum": [
        "second",
        "minute",
        "hour",
        "day",
        "month",
        "quarter",
        "year",
        "unknown"
      ],
      "title": "TimePrecision",
      "type": "string"
    },
    "TimeRange": {
      "additionalProperties": false,
      "properties": {
        "start": {
          "anyOf": [
            {
              "format": "date",
              "type": "string"
            },
            {
              "format": "date-time",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Start"
        },
        "end": {
          "anyOf": [
            {
              "format": "date",
              "type": "string"
            },
            {
              "format": "date-time",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "End"
        },
        "precision": {
          "$ref": "#/$defs/TimePrecision",
          "default": "unknown"
        }
      },
      "title": "TimeRange",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "id": {
      "title": "Id",
      "type": "string"
    },
    "object_type": {
      "const": "timeline_entry",
      "default": "timeline_entry",
      "title": "Object Type",
      "type": "string"
    },
    "schema_version": {
      "default": "1.0",
      "title": "Schema Version",
      "type": "string"
    },
    "status": {
      "$ref": "#/$defs/LifecycleStatus",
      "default": "active"
    },
    "created_at": {
      "format": "date-time",
      "title": "Created At",
      "type": "string"
    },
    "updated_at": {
      "format": "date-time",
      "title": "Updated At",
      "type": "string"
    },
    "created_by": {
      "default": "system",
      "title": "Created By",
      "type": "string"
    },
    "workspace_id": {
      "default": "default",
      "title": "Workspace Id",
      "type": "string"
    },
    "language": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": "zh-CN",
      "title": "Language"
    },
    "tags": {
      "items": {
        "type": "string"
      },
      "title": "Tags",
      "type": "array"
    },
    "source_refs": {
      "items": {
        "type": "string"
      },
      "title": "Source Refs",
      "type": "array"
    },
    "provenance": {
      "$ref": "#/$defs/Provenance"
    },
    "privacy_level": {
      "$ref": "#/$defs/PrivacyLevel",
      "default": "internal"
    },
    "deleted_at": {
      "anyOf": [
        {
          "format": "date-time",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Deleted At"
    },
    "external_ids": {
      "additionalProperties": {
        "type": "string"
      },
      "title": "External Ids",
      "type": "object"
    },
    "metadata": {
      "additionalProperties": true,
      "title": "Metadata",
      "type": "object"
    },
    "target_object_id": {
      "title": "Target Object Id",
      "type": "string"
    },
    "event_time": {
      "$ref": "#/$defs/TimeRange"
    },
    "title": {
      "minLength": 1,
      "title": "Title",
      "type": "string"
    },
    "summary": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Summary"
    },
    "referenced_object_ids": {
      "items": {
        "type": "string"
      },
      "title": "Referenced Object Ids",
      "type": "array"
    },
    "sequence_key": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Sequence Key"
    }
  },
  "required": [
    "target_object_id",
    "event_time",
    "title"
  ],
  "title": "TimelineEntry",
  "type": "object",
  "$id": "https://aurora.local/schemas/v1/timeline_entry.schema.json"
}
