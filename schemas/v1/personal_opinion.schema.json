{
  "$defs": {
    "HumanReview": {
      "additionalProperties": false,
      "properties": {
        "status": {
          "$ref": "#/$defs/HumanReviewStatus",
          "default": "not_reviewed"
        },
        "reviewed_by": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Reviewed By"
        },
        "reviewed_at": {
          "anyOf": [
            {
              "format": "date-time",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Reviewed At"
        },
        "note": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Note"
        }
      },
      "title": "HumanReview",
      "type": "object"
    },
    "HumanReviewStatus": {
      "enum": [
        "not_reviewed",
        "reviewed",
        "approved",
        "rejected",
        "needs_revision"
      ],
      "title": "HumanReviewStatus",
      "type": "string"
    },
    "LifecycleStatus": {
      "enum": [
        "active",
        "archived",
        "superseded",
        "deleted"
      ],
      "title": "LifecycleStatus",
      "type": "string"
    },
    "OpinionStatus": {
      "enum": [
        "draft",
        "under_review",
        "active",
        "watch",
        "challenged",
        "revised",
        "invalidated",
        "archived"
      ],
      "title": "OpinionStatus",
      "type": "string"
    },
    "OriginType": {
      "enum": [
        "original",
        "imported",
        "derived",
        "user_created"
      ],
      "title": "OriginType",
      "type": "string"
    },
    "PrivacyLevel": {
      "enum": [
        "public",
        "internal",
        "private",
        "sensitive",
        "restricted"
      ],
      "title": "PrivacyLevel",
      "type": "string"
    },
    "Provenance": {
      "additionalProperties": false,
      "properties": {
        "origin_type": {
          "$ref": "#/$defs/OriginType",
          "default": "original"
        },
        "origin_object_ids": {
          "items": {
            "type": "string"
          },
          "title": "Origin Object Ids",
          "type": "array"
        },
        "processing_run_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Processing Run Id"
        },
        "human_review": {
          "$ref": "#/$defs/HumanReview"
        },
        "derivation_note": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Derivation Note"
        },
        "source_locator_required": {
          "default": false,
          "title": "Source Locator Required",
          "type": "boolean"
        }
      },
      "title": "Provenance",
      "type": "object"
    },
    "QualityLevel": {
      "enum": [
        "very_low",
        "low",
        "medium",
        "high",
        "very_high"
      ],
      "title": "QualityLevel",
      "type": "string"
    }
  },
  "additionalProperties": false,
  "properties": {
    "id": {
      "title": "Id",
      "type": "string"
    },
    "object_type": {
      "const": "personal_opinion",
      "default": "personal_opinion",
      "title": "Object Type",
      "type": "string"
    },
    "schema_version": {
      "default": "1.0",
      "title": "Schema Version",
      "type": "string"
    },
    "status": {
      "$ref": "#/$defs/LifecycleStatus",
      "default": "active"
    },
    "created_at": {
      "format": "date-time",
      "title": "Created At",
      "type": "string"
    },
    "updated_at": {
      "format": "date-time",
      "title": "Updated At",
      "type": "string"
    },
    "created_by": {
      "default": "system",
      "title": "Created By",
      "type": "string"
    },
    "workspace_id": {
      "default": "default",
      "title": "Workspace Id",
      "type": "string"
    },
    "language": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": "zh-CN",
      "title": "Language"
    },
    "tags": {
      "items": {
        "type": "string"
      },
      "title": "Tags",
      "type": "array"
    },
    "source_refs": {
      "items": {
        "type": "string"
      },
      "title": "Source Refs",
      "type": "array"
    },
    "provenance": {
      "$ref": "#/$defs/Provenance"
    },
    "privacy_level": {
      "$ref": "#/$defs/PrivacyLevel",
      "default": "internal"
    },
    "deleted_at": {
      "anyOf": [
        {
          "format": "date-time",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Deleted At"
    },
    "external_ids": {
      "additionalProperties": {
        "type": "string"
      },
      "title": "External Ids",
      "type": "object"
    },
    "metadata": {
      "additionalProperties": true,
      "title": "Metadata",
      "type": "object"
    },
    "title": {
      "maxLength": 1000,
      "minLength": 1,
      "title": "Title",
      "type": "string"
    },
    "statement": {
      "minLength": 1,
      "title": "Statement",
      "type": "string"
    },
    "topic_ids": {
      "items": {
        "type": "string"
      },
      "title": "Topic Ids",
      "type": "array"
    },
    "supporting_ids": {
      "items": {
        "type": "string"
      },
      "title": "Supporting Ids",
      "type": "array"
    },
    "counter_evidence_ids": {
      "items": {
        "type": "string"
      },
      "title": "Counter Evidence Ids",
      "type": "array"
    },
    "key_assumptions": {
      "items": {
        "type": "string"
      },
      "title": "Key Assumptions",
      "type": "array"
    },
    "unknown_variables": {
      "items": {
        "type": "string"
      },
      "title": "Unknown Variables",
      "type": "array"
    },
    "invalidation_conditions": {
      "items": {
        "type": "string"
      },
      "title": "Invalidation Conditions",
      "type": "array"
    },
    "confidence_level": {
      "$ref": "#/$defs/QualityLevel",
      "default": "medium"
    },
    "opinion_status": {
      "$ref": "#/$defs/OpinionStatus",
      "default": "draft"
    },
    "confirmed_by_user": {
      "default": false,
      "title": "Confirmed By User",
      "type": "boolean"
    },
    "confirmed_at": {
      "anyOf": [
        {
          "format": "date-time",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Confirmed At"
    },
    "as_of_date": {
      "format": "date",
      "title": "As Of Date",
      "type": "string"
    },
    "review_due_at": {
      "anyOf": [
        {
          "format": "date",
          "type": "string"
        },
        {
          "format": "date-time",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Review Due At"
    },
    "version_no": {
      "default": 1,
      "minimum": 1,
      "title": "Version No",
      "type": "integer"
    },
    "previous_version_id": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Previous Version Id"
    },
    "revision_reason": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Revision Reason"
    }
  },
  "required": [
    "title",
    "statement",
    "as_of_date"
  ],
  "title": "PersonalOpinion",
  "type": "object",
  "$id": "https://aurora.local/schemas/v1/personal_opinion.schema.json"
}
