{
  "$defs": {
    "EvidenceDirectness": {
      "enum": [
        "direct",
        "indirect",
        "circumstantial",
        "unknown"
      ],
      "title": "EvidenceDirectness",
      "type": "string"
    },
    "EvidenceRole": {
      "enum": [
        "support",
        "refute",
        "qualify",
        "context",
        "counterexample"
      ],
      "title": "EvidenceRole",
      "type": "string"
    },
    "EvidenceStrength": {
      "enum": [
        "E0",
        "E1",
        "E2",
        "E3",
        "E4",
        "E5"
      ],
      "title": "EvidenceStrength",
      "type": "string"
    },
    "EvidenceType": {
      "enum": [
        "direct_quote",
        "official_data",
        "company_filing",
        "research_result",
        "observed_event",
        "expert_testimony",
        "historical_case",
        "derived_calculation",
        "user_observation",
        "unknown"
      ],
      "title": "EvidenceType",
      "type": "string"
    },
    "HumanReview": {
      "additionalProperties": false,
      "properties": {
        "status": {
          "$ref": "#/$defs/HumanReviewStatus",
          "default": "not_reviewed"
        },
        "reviewed_by": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Reviewed By"
        },
        "reviewed_at": {
          "anyOf": [
            {
              "format": "date-time",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Reviewed At"
        },
        "note": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Note"
        }
      },
      "title": "HumanReview",
      "type": "object"
    },
    "HumanReviewStatus": {
      "enum": [
        "not_reviewed",
        "reviewed",
        "approved",
        "rejected",
        "needs_revision"
      ],
      "title": "HumanReviewStatus",
      "type": "string"
    },
    "LifecycleStatus": {
      "enum": [
        "active",
        "archived",
        "superseded",
        "deleted"
      ],
      "title": "LifecycleStatus",
      "type": "string"
    },
    "OriginType": {
      "enum": [
        "original",
        "imported",
        "derived",
        "user_created"
      ],
      "title": "OriginType",
      "type": "string"
    },
    "PrivacyLevel": {
      "enum": [
        "public",
        "internal",
        "private",
        "sensitive",
        "restricted"
      ],
      "title": "PrivacyLevel",
      "type": "string"
    },
    "Provenance": {
      "additionalProperties": false,
      "properties": {
        "origin_type": {
          "$ref": "#/$defs/OriginType",
          "default": "original"
        },
        "origin_object_ids": {
          "items": {
            "type": "string"
          },
          "title": "Origin Object Ids",
          "type": "array"
        },
        "processing_run_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Processing Run Id"
        },
        "human_review": {
          "$ref": "#/$defs/HumanReview"
        },
        "derivation_note": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Derivation Note"
        },
        "source_locator_required": {
          "default": false,
          "title": "Source Locator Required",
          "type": "boolean"
        }
      },
      "title": "Provenance",
      "type": "object"
    },
    "SourceQualityTier": {
      "enum": [
        "S1",
        "S2",
        "S3",
        "S4",
        "S5"
      ],
      "title": "SourceQualityTier",
      "type": "string"
    }
  },
  "additionalProperties": false,
  "properties": {
    "id": {
      "title": "Id",
      "type": "string"
    },
    "object_type": {
      "const": "evidence",
      "default": "evidence",
      "title": "Object Type",
      "type": "string"
    },
    "schema_version": {
      "default": "1.0",
      "title": "Schema Version",
      "type": "string"
    },
    "status": {
      "$ref": "#/$defs/LifecycleStatus",
      "default": "active"
    },
    "created_at": {
      "format": "date-time",
      "title": "Created At",
      "type": "string"
    },
    "updated_at": {
      "format": "date-time",
      "title": "Updated At",
      "type": "string"
    },
    "created_by": {
      "default": "system",
      "title": "Created By",
      "type": "string"
    },
    "workspace_id": {
      "default": "default",
      "title": "Workspace Id",
      "type": "string"
    },
    "language": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": "zh-CN",
      "title": "Language"
    },
    "tags": {
      "items": {
        "type": "string"
      },
      "title": "Tags",
      "type": "array"
    },
    "source_refs": {
      "items": {
        "type": "string"
      },
      "title": "Source Refs",
      "type": "array"
    },
    "provenance": {
      "$ref": "#/$defs/Provenance"
    },
    "privacy_level": {
      "$ref": "#/$defs/PrivacyLevel",
      "default": "internal"
    },
    "deleted_at": {
      "anyOf": [
        {
          "format": "date-time",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Deleted At"
    },
    "external_ids": {
      "additionalProperties": {
        "type": "string"
      },
      "title": "External Ids",
      "type": "object"
    },
    "metadata": {
      "additionalProperties": true,
      "title": "Metadata",
      "type": "object"
    },
    "evidence_role": {
      "$ref": "#/$defs/EvidenceRole"
    },
    "evidence_type": {
      "$ref": "#/$defs/EvidenceType"
    },
    "target_object_id": {
      "title": "Target Object Id",
      "type": "string"
    },
    "source_ref": {
      "title": "Source Ref",
      "type": "string"
    },
    "summary": {
      "minLength": 1,
      "title": "Summary",
      "type": "string"
    },
    "independence_group": {
      "minLength": 1,
      "title": "Independence Group",
      "type": "string"
    },
    "directness": {
      "$ref": "#/$defs/EvidenceDirectness",
      "default": "unknown"
    },
    "source_quality_tier": {
      "$ref": "#/$defs/SourceQualityTier",
      "default": "S5"
    },
    "evidence_strength": {
      "$ref": "#/$defs/EvidenceStrength",
      "default": "E1"
    }
  },
  "required": [
    "evidence_role",
    "evidence_type",
    "target_object_id",
    "source_ref",
    "summary",
    "independence_group"
  ],
  "title": "Evidence",
  "type": "object",
  "$id": "https://aurora.local/schemas/v1/evidence.schema.json"
}
