{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aurora.schemas/extraction/v1/expected-results",
  "title": "Gate 0 Expected Extraction Results V1.1 (Strict)",
  "description": "M2-003A V1.2 人工期望提取结果的严格结构定义。新增 quote_match_mode、expected_review_decisions、FormatChecker 强校验。",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "annotated_by", "annotated_at", "reviewed_by", "reviewed_at",
    "disagreements", "adjudication_note", "fixture_source_hash",
    "case_id", "case_title", "material_path",
    "expected_entities", "expected_data_points", "expected_claims",
    "expected_evidence", "expected_fact_candidates",
    "expected_warnings", "expected_rejects", "expected_review_decisions", "validation_report"
  ],
  "properties": {
    "annotated_by": {"type": "string", "minLength": 1},
    "annotated_at": {"type": "string", "format": "date-time"},
    "reviewed_by": {"type": "string", "minLength": 1},
    "reviewed_at": {"type": "string", "format": "date-time"},
    "disagreements": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["target_id", "raised_by", "description", "resolution"],
        "properties": {
          "target_id": {"type": "string", "minLength": 1},
          "raised_by": {"type": "string", "minLength": 1},
          "description": {"type": "string", "minLength": 1},
          "resolution": {"type": ["string", "null"]},
          "adjudication_note": {"type": "string"}
        }
      }
    },
    "adjudication_note": {"type": ["string", "null"]},
    "fixture_source_hash": {
      "type": "string",
      "pattern": "^[a-fA-F0-9]{64}$",
      "description": "原始输入材料的 SHA-256（64 位 hex）"
    },
    "case_id": {"type": "string", "minLength": 1},
    "case_title": {"type": "string", "minLength": 1},
    "material_path": {"type": "string", "minLength": 1},

    "expected_entities": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "entity_type", "canonical_name"],
        "properties": {
          "id": {"type": "string", "minLength": 1},
          "entity_type": {
            "type": "string",
            "enum": ["person", "organization", "location", "product", "event", "concept", "other"]
          },
          "canonical_name": {"type": "string", "minLength": 1}
        }
      }
    },

    "expected_data_points": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "metric", "value", "unit", "entity_id", "period", "measurement_context", "source_quote"],
        "properties": {
          "id": {"type": "string", "minLength": 1},
          "metric": {"type": "string", "minLength": 1},
          "value": {"type": "number"},
          "unit": {"type": "string", "minLength": 1},
          "entity_id": {"type": "string", "minLength": 1},
          "period": {"type": "string", "minLength": 1},
          "measurement_context": {
            "type": "object",
            "additionalProperties": false,
            "required": ["measurement_kind"],
            "properties": {
              "measurement_kind": {
                "type": "string",
                "enum": ["monetary", "percentage", "ratio", "count", "rate", "index", "score", "other"]
              },
              "currency": {
                "type": ["string", "null"],
                "pattern": "^(CNY|USD|EUR|HKD|JPY|GBP)?$"
              },
              "scale_multiplier": {"type": "integer", "minimum": 1},
              "reporting_standard": {
                "type": ["string", "null"],
                "enum": ["CAS", "IFRS", "US_GAAP", "HKFRS", null]
              },
              "attribution_scope": {
                "type": "string",
                "enum": ["group_total", "parent_only", "segment", "other"]
              },
              "consolidation_scope": {
                "type": "string",
                "enum": ["consolidated", "unconsolidated", "proportional", "equity_method"]
              }
            }
          },
          "source_quote": {"type": "string", "minLength": 1},
          "quote_locator_hint": {"type": "string"},
          "quote_match_mode": {"type": "string", "enum": ["literal", "token_set"], "default": "literal"},
          "source_unit_id": {"type": "string", "minLength": 1, "description": "V1.2c: 指向冻结 ContentUnit 快照中的 unit_id"},
          "note": {"type": "string"}
        }
      }
    },

    "expected_claims": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "statement", "claim_type", "claim_dimension", "source_quote"],
        "properties": {
          "id": {"type": "string", "minLength": 1},
          "statement": {"type": "string", "minLength": 1},
          "claim_type": {
            "type": "string",
            "enum": ["fact_claim", "prediction", "risk_claim", "value_judgment", "opinion", "other"]
          },
          "claim_dimension": {
            "type": "string",
            "enum": ["financial_performance", "business_growth", "operations", "market_expectation", "competition", "valuation", "regulation", "technology", "esg", "general", "other"]
          },
          "claimant_id": {"type": ["string", "null"]},
          "claimant_name": {"type": "string"},
          "asserted_by": {"type": "string", "description": "当 claim_type=prediction 时声明预测来源"},
          "time_horizon": {
            "type": "object",
            "additionalProperties": false,
            "required": ["precision"],
            "properties": {
              "start": {"type": ["string", "null"]},
              "end": {"type": ["string", "null"]},
              "precision": {
                "type": "string",
                "enum": ["exact", "range", "estimated", "unknown"]
              }
            }
          },
          "promotable_to_fact": {"type": "boolean"},
          "source_quote": {"type": "string", "minLength": 1},
          "quote_locator_hint": {"type": "string"},
          "quote_match_mode": {"type": "string", "enum": ["literal", "token_set"], "default": "literal"},
          "source_unit_id": {"type": "string", "minLength": 1},
          "note": {"type": "string"}
        },
        "if": {
          "properties": {"claim_type": {"const": "prediction"}},
          "required": ["claim_type"]
        },
        "then": {
          "required": ["time_horizon"],
          "properties": {
            "promotable_to_fact": {"const": false}
          }
        }
      }
    },

    "expected_evidence": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "evidence_type", "evidence_role", "target_object_id", "independence_group", "source_quote"],
        "properties": {
          "id": {"type": "string", "minLength": 1},
          "evidence_type": {
            "type": "string",
            "enum": ["company_filing", "observed_event", "direct_quote", "third_party_report", "expert_statement", "public_record", "other"]
          },
          "evidence_role": {
            "type": "string",
            "enum": ["support", "refute", "context", "attribution"]
          },
          "target_object_id": {"type": "string", "minLength": 1},
          "independence_group": {"type": "string", "minLength": 1},
          "source_quote": {"type": "string", "minLength": 1},
          "quote_match_mode": {"type": "string", "enum": ["literal", "token_set"], "default": "literal"},
          "source_unit_id": {"type": "string", "minLength": 1},
          "note": {"type": "string"}
        }
      }
    },

    "expected_fact_candidates": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "statement", "promotable"],
        "properties": {
          "id": {"type": "string", "minLength": 1},
          "target_data_point_id": {"type": "string"},
          "target_claim_id": {"type": "string"},
          "supporting_evidence_ids": {
            "type": "array",
            "items": {"type": "string", "minLength": 1}
          },
          "statement": {"type": "string", "minLength": 1},
          "valid_time": {
            "type": ["object", "null"],
            "additionalProperties": false,
            "properties": {
              "period": {"type": "string"},
              "start": {"type": "string"},
              "end": {"type": "string"}
            }
          },
          "confidence_rationale": {"type": ["string", "null"]},
          "promotable": {"type": "boolean"},
          "rejection_reason": {"type": "string"}
        },
        "anyOf": [
          {
            "required": ["target_data_point_id"],
            "properties": {"target_data_point_id": {"type": "string", "minLength": 1}}
          },
          {
            "required": ["target_claim_id"],
            "properties": {"target_claim_id": {"type": "string", "minLength": 1}}
          }
        ]
      },
      "if": {
        "properties": {"promotable": {"const": true}}
      },
      "then": {
        "required": ["valid_time", "confidence_rationale"],
        "properties": {
          "supporting_evidence_ids": {
            "type": "array",
            "minItems": 1,
            "items": {"type": "string", "minLength": 1}
          }
        }
      },
      "else": {
        "required": ["rejection_reason"],
        "properties": {
          "rejection_reason": {"type": "string", "minLength": 1}
        }
      }
    },

    "expected_warnings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "target_id", "warning_type", "note"],
        "properties": {
          "id": {"type": "string", "minLength": 1},
          "target_id": {"type": "string", "minLength": 1},
          "warning_type": {
            "type": "string",
            "enum": [
              "CLAIM_COMPOUND_SPLIT_SUGGESTED",
              "CLAIM_SOFT_PREDICTION",
              "CLAIM_LOW_CONFIDENCE",
              "TRANSCRIPT_OVERLAPPING_CUES",
              "SAME_INDEPENDENCE_GROUP",
              "CODE_BLOCK_DETECTED",
              "SINGLE_SOURCE_RISK",
              "TABLE_CELL_AMBIGUITY",
              "other"
            ]
          },
          "note": {"type": "string", "minLength": 1}
        }
      }
    },

    "expected_rejects": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "rejection_reason", "target_quote"],
        "properties": {
          "id": {"type": "string", "minLength": 1},
          "rejection_reason": {
            "type": "string",
            "enum": [
              "CONTENT_UNIT_CODE_BLOCK_NON_CLAIM",
              "VALUE_JUDGMENT_NOT_FACT",
              "PREDICTION_NOT_FACT",
              "INSUFFICIENT_EVIDENCE",
              "SINGLE_SOURCE_ONLY",
              "CIRCULAR_SUPPORT",
              "UNSUPPORTED_CALCULATION",
              "OUT_OF_SCOPE",
              "other"
            ]
          },
          "target_quote": {"type": "string", "minLength": 1},
          "quote_locator_hint": {"type": "string"},
          "quote_match_mode": {"type": "string", "enum": ["literal", "token_set"], "default": "literal"},
          "source_unit_id": {"type": "string", "minLength": 1},
          "note": {"type": "string"}
        }
      }
    },

    "expected_review_decisions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["target_id", "action"],
        "properties": {
          "target_id": {"type": "string", "minLength": 1},
          "action": {
            "type": "string",
            "enum": ["APPROVE", "REJECT", "REVISE_AND_APPROVE"]
          },
          "revised_payload": {
            "type": ["object", "null"],
            "additionalProperties": false,
            "properties": {
              "revised_statement": {"type": "string", "minLength": 1},
              "revised_claim_type": {"type": "string"},
              "revised_claimant": {"type": "string"},
              "revised_time_horizon": {"type": "object"},
              "revised_promotable_to_fact": {"type": "boolean"},
              "revision_rationale": {"type": "string"}
            }
          },
          "original_candidate_hash": {"type": "string"},
          "reviewer": {"type": "string"},
          "review_note": {"type": "string"}
        },
        "if": {
          "properties": {"action": {"const": "REVISE_AND_APPROVE"}}
        },
        "then": {
          "required": ["revised_payload"],
          "properties": {
            "revised_payload": {
              "type": "object",
              "required": ["revised_statement"]
            }
          }
        }
      }
    },

    "validation_report": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "claim_type_coverage", "claim_dimension_coverage",
        "measurement_context_coverage", "quote_gate_executable",
        "fact_promotion_rules_sufficient", "review_bundle_usable",
        "core_schema_change_needed", "new_core_object_needed"
      ],
      "properties": {
        "claim_type_coverage": {
          "type": "string",
          "enum": ["SUFFICIENT", "INSUFFICIENT", "N/A"]
        },
        "claim_dimension_coverage": {
          "type": "string",
          "enum": ["SUFFICIENT", "INSUFFICIENT", "N/A"]
        },
        "measurement_context_coverage": {
          "type": "string",
          "enum": ["SUFFICIENT", "INSUFFICIENT", "N/A"]
        },
        "quote_gate_executable": {"type": "boolean"},
        "fact_promotion_rules_sufficient": {"type": "boolean"},
        "review_bundle_usable": {"type": "boolean"},
        "core_schema_change_needed": {"type": "boolean"},
        "new_core_object_needed": {"type": "boolean"},
        "notes": {"type": "string"}
      }
    }
  }
}
